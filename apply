#!/usr/bin/env bash

# Start the timer
START_TIME=$SECONDS

# 1. Handle missing Git first (prevents double prompts)
if ! command -v git &> /dev/null; then
    echo "🤖 Git not found. Re-running inside nix-shell..."
    exec nix-shell -p git --run "$0"
fi

# 2. Define paths
REAL_USER=${SUDO_USER:-$(logname)}
DOTFILES_DIR="/home/$REAL_USER/.dotfiles"
NETWORK_CONFIG="$DOTFILES_DIR/nixos/local-networking.nix"
HARDWARE_CONFIG="$DOTFILES_DIR/nixos/hardware-configuration.nix"

# 3. Generate local-networking.nix
echo "🌐 Configuring network (Press Enter for defaults):"
read -p "Use STATIC IP? (y/n) [y]: " USE_STATIC; USE_STATIC=${USE_STATIC:-y}
read -p "Hostname [nixos-dev]: " HOST; HOST=${HOST:-nixos-dev}
read -p "Interface [enp0s3]: " IFACE; IFACE=${IFACE:-enp0s3}

if [[ "$USE_STATIC" =~ ^[Yy]$ ]]; then
    read -p "Static IP: " IP; IP=${IP:-192.168.100.100}
    read -p "Gateway: " GW; GW=${GW:-192.168.100.1}

    cat <<EOF > "$NETWORK_CONFIG"
{ ... }: {
  networking = {
    hostName = "$HOST";
    firewall.allowedTCPPorts = [ 22 ];
    useDHCP = false;
    interfaces."$IFACE" = {
      useDHCP = false;
      ipv4.addresses = [{ address = "$IP"; prefixLength = 24; }];
    };
    defaultGateway = "$GW";
    nameservers = [ "8.8.8.8" "1.1.1.1" ];
  };
}
EOF
    # Disable default DHCP in hardware-configuration.nix with sudo
    if [ -f "$HARDWARE_CONFIG" ]; then
        sudo sed -i 's/networking.useDHCP/# networking.useDHCP/g' "$HARDWARE_CONFIG"
    fi
else
    # Clean DHCP Path: Explicitly empty old static addresses
    cat <<EOF > "$NETWORK_CONFIG"
{ ... }: {
  networking = {
    hostName = "$HOST";
    firewall.allowedTCPPorts = [ 22 ];
    networkmanager.enable = true;
    interfaces."$IFACE".ipv4.addresses = [ ]; 
  };
}
EOF
fi

# 4. Sync hardware-configuration.nix
[ ! -f "$HARDWARE_CONFIG" ] && cp /etc/nixos/hardware-configuration.nix "$HARDWARE_CONFIG"

# 5. System Symlink
sudo ln -sf "$DOTFILES_DIR/nixos/configuration.nix" /etc/nixos/configuration.nix

# 6. Apply configuration
echo "⚙️  Running nixos-rebuild switch..."
sudo nixos-rebuild switch

# 7. CLEANUP: Force network stack to drop old states and pick up new config
echo "🔄 Restarting network-setup to clear IP duplication..."
sudo systemctl restart network-setup.service

# 8. Execution time
ELAPSED=$(( SECONDS - START_TIME ))
echo "------------------------------------------"
echo "✅ Done! Execution time: $(( ELAPSED / 60 ))m $(( ELAPSED % 60 ))s"
echo "------------------------------------------"

# --- POST-APPLY NETWORK FIX ---
# We check if the network config was updated during this run
if [[ "$USE_STATIC" =~ ^[Yy]$ ]] || [ "$OLD_HOST" != "$HOST" ]; then
    echo "⚠️  Network configuration changed."
    read -p "REBOOT NOW to apply clean network state? (y/n) [y]: " REBOOT_NOW
    REBOOT_NOW=${REBOOT_NOW:-y}
    
    if [[ "$REBOOT_NOW" =~ ^[Yy]$ ]]; then
        echo "🚀 Rebooting in 3 seconds..."
        sleep 3
        sudo reboot
    fi
fi
