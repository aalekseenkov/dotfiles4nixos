#!/usr/bin/env bash

# 1. Define paths
REAL_USER=${SUDO_USER:-$(logname)}
DOTFILES_DIR="/home/$REAL_USER/.dotfiles"
NETWORK_CONFIG="$DOTFILES_DIR/nixos/local-networking.nix"
HARDWARE_CONFIG="$DOTFILES_DIR/nixos/hardware-configuration.nix"

# 2. Network config generation
echo "🌐 Network Setup:"
read -p "Use STATIC IP? (y/n) [y]: " USE_STATIC; USE_STATIC=${USE_STATIC:-y}
read -p "Hostname [nixos]: " HOST; HOST=${HOST:-nixos}
read -p "Interface [enp0s3]: " IFACE; IFACE=${IFACE:-enp0s3}

if [[ "$USE_STATIC" =~ ^[Yy]$ ]]; then
    read -p "IP: " IP; IP=${IP:-192.168.100.100}
    read -p "GW: " GW; GW=${GW:-192.168.100.1}
    cat <<EOF > "$NETWORK_CONFIG"
{ ... }: {
  networking = {
    hostName = "$HOST";
    firewall.allowedTCPPorts = [ 22 80 443 ]; # SSH + HTTP/S для тестов
    useDHCP = false;
    interfaces."$IFACE" = {
      useDHCP = false;
      ipv4.addresses = [{ address = "$IP"; prefixLength = 24; }];
    };
    defaultGateway = "$GW";
    nameservers = [ "8.8.8.8" "1.1.1.1" ];
  };
}
EOF
else
    cat <<EOF > "$NETWORK_CONFIG"
{ ... }: {
  networking = {
    hostName = "$HOST";
    firewall.allowedTCPPorts = [ 22 ];
    networkmanager.enable = true;
    interfaces."$IFACE".ipv4.addresses = [ ]; 
  };
}
EOF
fi

if [[ "$USE_STATIC" =~ ^[Yy]$ ]]; then
    read -p "IP: " IP; IP=${IP:-192.168.100.100}
    read -p "GW: " GW; GW=${GW:-192.168.100.1}
    cat <<EOF > "$NETWORK_CONFIG"
{ ... }: {
  networking = {
    hostName = "$HOST";
    useDHCP = false;
    interfaces."$IFACE".ipv4.addresses = [{ address = "$IP"; prefixLength = 24; }];
    defaultGateway = "$GW";
    nameservers = [ "8.8.8.8" "1.1.1.1" ];
  };
}
EOF
else
    cat <<EOF > "$NETWORK_CONFIG"
{ ... }: {
  networking = { hostName = "$HOST"; useDHCP = true; };
}
EOF
fi

# 3. Hardware Sync
[ ! -f "$HARDWARE_CONFIG" ] && cp /etc/nixos/hardware-configuration.nix "$HARDWARE_CONFIG"

# 4. GIT MAGIC (Intent-to-add)
# This makes Nix see files even if they are in .gitignore
echo "📦 Adding local files to Git index (temporary)..."
git -C "$DOTFILES_DIR" add -f "$NETWORK_CONFIG" "$HARDWARE_CONFIG"

# 5. Git Safety Magic (SRE Style)
# We tell Git: "Keep these files in the repo, but IGNORE any local changes in them"
echo "🛡️  Freezing local configs in Git index..."
git -C "$DOTFILES_DIR" update-index --assume-unchanged "$NETWORK_CONFIG" 2>/dev/null
git -C "$DOTFILES_DIR" update-index --assume-unchanged "$HARDWARE_CONFIG" 2>/dev/null

# 6. Apply with Flake
echo "⚙️  Rebuilding system..."
sudo nixos-rebuild switch --flake "$DOTFILES_DIR#$HOST"

# 7. Cleanup network
sudo systemctl restart network-setup.service
echo "✅ Done! System: $HOST"

