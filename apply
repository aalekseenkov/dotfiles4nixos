#!/usr/bin/env bash

# Start the timer
START_TIME=$SECONDS

# 1. Handle missing Git first (prevents double prompts)
if ! command -v git &> /dev/null; then
    echo "🤖 Git not found. Re-running inside nix-shell..."
    exec nix-shell -p git --run "$0"
fi

# 2. Define paths
REAL_USER=${SUDO_USER:-$(logname)}
DOTFILES_DIR="/home/$REAL_USER/.dotfiles"
NETWORK_CONFIG="$DOTFILES_DIR/nixos/local-networking.nix"
HARDWARE_CONFIG="$DOTFILES_DIR/nixos/hardware-configuration.nix"

# 3. Generate local-networking.nix if missing
if [ ! -f "$NETWORK_CONFIG" ]; then
    echo "🌐 Local networking config not found."
    read -p "Do you want to use STATIC IP? (y/n): " USE_STATIC
    
    # Defaults for VirtualBox
    DEFAULT_IFACE="enp0s3"
    DEFAULT_IP="192.168.100.100"
    DEFAULT_GW="192.168.100.1"
    DEFAULT_HOST="nixos-dev"

    if [[ "$USE_STATIC" =~ ^[Yy]$ ]]; then
        read -p "Interface [$DEFAULT_IFACE]: " IFACE; IFACE=${IFACE:-$DEFAULT_IFACE}
        read -p "Static IP [$DEFAULT_IP]: " IP; IP=${IP:-$DEFAULT_IP}
        read -p "Gateway [$DEFAULT_GW]: " GW; GW=${GW:-$DEFAULT_GW}
        read -p "Hostname [$DEFAULT_HOST]: " HOST; HOST=${HOST:-$DEFAULT_HOST}

        cat <<EOF > "$NETWORK_CONFIG"
{ ... }: {
  networking = {
    hostName = "$HOST";
    firewall.allowedTCPPorts = [ 22 ];
    useDHCP = false;
    interfaces."$IFACE" = {
      useDHCP = false;
      ipv4.addresses = [{
        address = "$IP";
        prefixLength = 24;
      }];
    };
    defaultGateway = "$GW";
    nameservers = [ "8.8.8.8" "1.1.1.1" ];
  };
}
EOF
        # Disable default DHCP in hardware-configuration.nix
        if [ -f "$HARDWARE_CONFIG" ]; then
            echo "🛠  Disabling default DHCP in hardware-configuration.nix..."
            sudo sed -i 's/networking.useDHCP/# networking.useDHCP/g' "$HARDWARE_CONFIG"
        fi
    else
        read -p "Hostname [$DEFAULT_HOST]: " HOST; HOST=${HOST:-$DEFAULT_HOST}
        cat <<EOF > "$NETWORK_CONFIG"
{ ... }: {
  networking = {
    hostName = "$HOST";
    firewall.allowedTCPPorts = [ 22 ];
    networkmanager.enable = true;
  };
}
EOF
    fi
    echo "✅ Created $NETWORK_CONFIG"
fi

# 4. Sync hardware-configuration.nix to dotfiles
if [ ! -f "$HARDWARE_CONFIG" ]; then
    echo "📦 Copying system hardware-configuration.nix to dotfiles..."
    cp /etc/nixos/hardware-configuration.nix "$HARDWARE_CONFIG"
fi

# 5. Create system symlink
echo "🔗 Symlinking configuration.nix to /etc/nixos/..."
sudo ln -sf "$DOTFILES_DIR/nixos/configuration.nix" /etc/nixos/configuration.nix

# 6. Apply configuration (NO MANUAL FLUSH HERE - let NixOS handle it)
echo "⚙️  Running nixos-rebuild switch..."
sudo nixos-rebuild switch

# 7. Execution time
ELAPSED=$(( SECONDS - START_TIME ))
echo "------------------------------------------"
echo "✅ Done! Execution time: $(( ELAPSED / 60 ))m $(( ELAPSED % 60 ))s"
echo "------------------------------------------"
