#!/usr/bin/env bash

# 1. Define paths
REAL_USER=${SUDO_USER:-$(logname)}
DOTFILES_DIR="/home/$REAL_USER/.dotfiles"
NETWORK_CONFIG="$DOTFILES_DIR/nixos/local-networking.nix"
HARDWARE_CONFIG="$DOTFILES_DIR/nixos/hardware-configuration.nix"

# --- ARGUMENTS PARSING ---
RECONF=false
LAPTOP_PRESET=false

for arg in "$@"; do
    case $arg in
        --reconf) RECONF=true ;;
        --dhcp) DHCP_MODE=true ;;
    esac
done

if [ "$RECONF" = true ]; then
    echo "🔄 RECONF MODE: Cleaning local configs for a fresh start..."
    rm -f "$NETWORK_CONFIG" "$HARDWARE_CONFIG"
fi

# 2. Network config generation
if [ ! -f "$NETWORK_CONFIG" ]; then
    echo "🌐 Network Setup:"

    if [ "$DHCP_MODE" = true ]; then
        USE_STATIC="n"
        echo "💻 Laptop preset detected: skipping static IP questions."
    else
        read -p "Use STATIC IP? (y/n) [y]: " USE_STATIC; USE_STATIC=${USE_STATIC:-y}
    fi

    read -p "Hostname [nixos]: " HOST; HOST=${HOST:-nixos}
    read -p "Interface [enp0s3]: " IFACE; IFACE=${IFACE:-enp0s3}

    if [[ "$USE_STATIC" =~ ^[Yy]$ ]]; then
        read -p "Static IP: " IP; IP=${IP:-192.168.100.100}
        read -p "Gateway: " GW; GW=${GW:-192.168.100.1}
        cat <<EOF > "$NETWORK_CONFIG"
{ ... }: {
  networking = {
    hostName = "$HOST";
    firewall.allowedTCPPorts = [ 22 80 443 ];
    useDHCP = false;
    interfaces."$IFACE" = {
      useDHCP = false;
      ipv4.addresses = [{ address = "$IP"; prefixLength = 24; }];
    };
    defaultGateway = "$GW";
    nameservers = [ "8.8.8.8" "1.1.1.1" ];
  };
}
EOF
    else
        cat <<EOF > "$NETWORK_CONFIG"
{ ... }: {
  networking = {
    hostName = "$HOST";
    firewall.allowedTCPPorts = [ 22 ];
    networkmanager.enable = true;
  };
}
EOF
    fi
else
    echo "✅ Network config exists. Use --reconf to change it."
    HOST=$(grep "hostName =" "$NETWORK_CONFIG" | cut -d'"' -f2)
fi

# 3. Hardware Sync (copy only if missing)
if [ ! -f "$HARDWARE_CONFIG" ]; then
    echo "💾 Copying hardware config from /etc/nixos..."
    cp /etc/nixos/hardware-configuration.nix "$HARDWARE_CONFIG"
fi

# 4. GIT STAGING (Make visible for Nix)
echo "📦 Adding local files to Git index for build..."
git -C "$DOTFILES_DIR" add -f "$NETWORK_CONFIG" "$HARDWARE_CONFIG"

# 5. REBUILD (Ship it!)
echo "⚙️  Rebuilding system via Flake..."
if sudo nixos-rebuild switch --flake "$DOTFILES_DIR#nixos"; then
    echo "✅ Success! System: ${HOST:-nixos}"
else
    echo "❌ Build failed!"
    # Не делаем reset, чтобы можно было отдебажить файлы, если билд упал
    exit 1
fi

# 6. GIT CLEANUP (The "SRE Magic")
echo "🛡️  Resetting index to keep local configs private..."
git -C "$DOTFILES_DIR" reset "$NETWORK_CONFIG" "$HARDWARE_CONFIG" > /dev/null 2>&1

# 7. Network Refresh (Safe for NetworkManager)
echo "🔄 Refreshing network..."
if systemctl is-active --quiet NetworkManager; then
    sudo systemctl restart NetworkManager
else
    sudo systemctl restart network-setup.service 2>/dev/null || true
fi

echo "------------------------------------------"
echo "🚀 Ship it! DONE."
