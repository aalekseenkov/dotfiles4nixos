#!/usr/bin/env bash

# 1. Define paths
REAL_USER=${SUDO_USER:-$(logname)}
DOTFILES_DIR="/home/$REAL_USER/.dotfiles"
NETWORK_CONFIG="$DOTFILES_DIR/nixos/local-networking.nix"
HARDWARE_CONFIG="$DOTFILES_DIR/nixos/hardware-configuration.nix"

# --- ARGUMENTS PARSING ---
RECONF=false
DHCP_MODE=false

for arg in "$@"; do
    case $arg in
        --reconf) RECONF=true ;;
        --dhcp) DHCP_MODE=true ;;
    esac
done

if [ "$RECONF" = true ]; then
    echo "🔄 RECONF MODE: Cleaning local configs for a fresh start..."
    rm -f "$NETWORK_CONFIG" "$HARDWARE_CONFIG"
fi

# 2. Network config generation
if [ ! -f "$NETWORK_CONFIG" ]; then
    echo "🌐 Network Setup:"

    if [ "$DHCP_MODE" = true ]; then
        USE_STATIC="n"
        echo "🌐 DHCP mode selected: skipping static IP questions."
    else
        read -p "Use STATIC IP? (y/n) [y]: " USE_STATIC; USE_STATIC=${USE_STATIC:-y}
    fi

    read -p "Hostname [nixos]: " HOST; HOST=${HOST:-nixos}
    read -p "Interface [enp0s3]: " IFACE; IFACE=${IFACE:-enp0s3}

    if [[ "$USE_STATIC" =~ ^[Yy]$ ]]; then
        read -p "Static IP: " IP; IP=${IP:-192.168.100.100}
        read -p "Gateway: " GW; GW=${GW:-192.168.100.1}
        cat <<EOF > "$NETWORK_CONFIG"
{ ... }: {
  networking = {
    hostName = "$HOST";
    firewall.allowedTCPPorts = [ 22 80 443 8080 ];
    networkmanager.enable = false;
    useDHCP = false;
    interfaces."$IFACE" = {
      useDHCP = false;
      ipv4.addresses = [{ address = "$IP"; prefixLength = 24; }];
    };
    defaultGateway = "$GW";
    nameservers = [ "8.8.8.8" "1.1.1.1" ];
  };
}
EOF
    else
        cat <<EOF > "$NETWORK_CONFIG"
{ ... }: {
  networking = {
    hostName = "$HOST";
    firewall.allowedTCPPorts = [ 22 80 443 8080 ];
    networkmanager.enable = true;
  };
}
EOF
    fi
else
    echo "✅ Network config exists. Use --reconf to change it."
    HOST=$(grep "hostName =" "$NETWORK_CONFIG" | cut -d'"' -f2)
fi

# 3. Hardware Sync (copy only if missing)
if [ ! -f "$HARDWARE_CONFIG" ]; then
    echo "💾 Copying hardware config from /etc/nixos..."
    cp /etc/nixos/hardware-configuration.nix "$HARDWARE_CONFIG"
fi

# 4. GIT STAGING (Make visible for Nix)
echo "📦 Adding local files to Git index for build..."
git -C "$DOTFILES_DIR" add -f "$NETWORK_CONFIG" "$HARDWARE_CONFIG"

# 5. REBUILD (Ship it!)
echo "⚙️  Rebuilding system via Flake..."

# SRE-logic: If reconfiguring network, use 'boot' to avoid SSH deadlock.
# Otherwise, use 'switch' for instant updates.
ACTION="switch"
if [ "$RECONF" = true ] || [ "$DHCP_MODE" = true ]; then
    ACTION="boot"
    echo "🛡️  Network change detected: preparing for BOOT (no-switch mode)."
fi

if sudo nixos-rebuild $ACTION --flake "$DOTFILES_DIR#nixos"; then
    echo "✅ Success! Configuration prepared ($ACTION)."
else
    echo "❌ Build failed!"
    exit 1
fi

# 6. GIT CLEANUP (The "SRE Magic")
echo "🛡️  Resetting index to keep local configs private..."
git -C "$DOTFILES_DIR" reset "$NETWORK_CONFIG" "$HARDWARE_CONFIG" > /dev/null 2>&1

# 7. Network Refresh & Post-Deployment Logic
echo "🔄 Finalizing deployment..."

if [ "$RECONF" = true ] || [ "$DHCP_MODE" = true ]; then
    echo "⚠️  NETWORK RECONFIGURATION DETECTED!"
    echo "Applying new network settings will likely DROP your current SSH session."
    read -p "🚀 Do you want to REBOOT now to apply changes safely? (y/n) [y]: " DO_REBOOT
    DO_REBOOT=${DO_REBOOT:-y}

    if [[ "$DO_REBOOT" =~ ^[Yy]$ ]]; then
        echo "♻️  Saving state and rebooting in 3 seconds..."
        sleep 3
        sudo reboot
    else
        echo "🛡️  Skipping reboot. Attempting soft refresh (risky for SSH)..."
        sudo systemctl restart network-setup.service 2>/dev/null || true
        sudo systemctl restart sshd
    fi
else
    echo "✅ No network changes detected. Soft refreshing services..."
    sudo systemctl restart sshd
    echo "🏰 Bastion v2.0: Daily update complete."
fi

echo "------------------------------------------"
echo "🚀 Ship it! DONE."
